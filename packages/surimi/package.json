{
  "name": "surimi",
  "version": "0.8.0",
  "private": false,
  "description": "Next generation CSS-preprocessor (using typescript)",
  "keywords": [
    "css",
    "surimi",
    "css-in-js",
    "ts-in-css"
  ],
  "license": "MIT",
  "author": "Janis jansen <oss@janis.me>",
  "type": "module",
  "imports": {
    "#*": [
      "./src/*",
      "./src/*.ts",
      "./src/*/index.ts"
    ]
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./conditional": {
      "types": "./dist/conditional.d.ts",
      "import": "./dist/conditional.js"
    },
    "./theme": {
      "types": "./dist/theme.d.ts",
      "import": "./dist/theme.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    }
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "lint": "biome lint .",
    "format": "biome format .",
    "check": "biome check .",
    "prepack": "pnpm -c exec ../../scripts/replace-symlinks.sh",
    "test": "pnpm -w test --project=surimi",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@surimi/common": "workspace:*",
    "@surimi/conditional": "workspace:*",
    "@surimi/core": "workspace:*",
    "@surimi/parsers": "workspace:*",
    "@surimi/theme": "workspace:*",
    "vite-plugin-surimi": "workspace:*"
  },
  "devDependencies": {
    "@surimi/typescript-config": "workspace:*",
    "tsdown": "catalog:build",
    "typescript": "catalog:build",
    "vitest": "catalog:test"
  },
  "peerDependencies": {
    "vite": "catalog:build"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  }
}
