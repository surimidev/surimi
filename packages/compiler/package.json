{
  "name": "@surimi/compiler",
  "version": "0.7.0",
  "description": "Compile surimi ts files to css",
  "keywords": [
    "css",
    "surimi",
    "css-in-js"
  ],
  "license": "MIT",
  "author": "Janis Jansen <oss@janis.me>",
  "type": "module",
  "imports": {
    "#*": "./src/*"
  },
  "exports": {
    ".": {
      "types": "./dist/index.node.d.ts",
      "browser": "./dist/index.browser.js",
      "import": "./dist/index.node.js",
      "default": "./dist/index.node.js"
    },
    "./browser": {
      "types": "./dist/index.browser.d.ts",
      "import": "./dist/index.browser.js",
      "default": "./dist/index.browser.js"
    }
  },
  "main": "dist/index.node.js",
  "module": "dist/index.node.js",
  "types": "dist/index.node.d.ts",
  "bin": {
    "surimi": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "test": "pnpm -w test --project=compiler",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "commander": "^14.0.3",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@surimi/linter-config": "workspace:*",
    "@surimi/typescript-config": "workspace:*",
    "@types/node": "catalog:types",
    "tsdown": "catalog:build",
    "typescript": "catalog:build"
  },
  "peerDependencies": {
    "@rolldown/browser": "1.0.0-rc.9",
    "rolldown": "1.0.0-rc.9",
    "surimi": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@rolldown/browser": {
      "optional": true
    }
  }
}
