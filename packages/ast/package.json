{
  "name": "@surimi/ast",
  "version": "0.1.0",
  "private": false,
  "author": "Janis jansen <oss@janis.me>",
  "type": "module",
  "imports": {
    "#*": "./src/*"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "lint": "biome lint .",
    "format": "biome format .",
    "check": "biome check .",
    "test": "pnpm -w test --project=ast",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@surimi/typescript-config": "workspace:*",
    "tsdown": "catalog:build",
    "typescript": "catalog:build",
    "vitest": "catalog:test"
  }
}
