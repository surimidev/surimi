---
import { BarsIcon, GithubIcon, NpmIcon } from '../icons';

import './Header.css';

const NAV_LINKS = [
  { href: '/docs/getting-started', text: 'Getting Started' },
  { href: '/docs/reference', text: 'API Reference' },
  { href: '/playground', text: 'Playground' },
] as const;

const SOCIAL_LINKS = [
  { href: 'https://github.com/surimidev/surimi', text: 'GitHub', icon: GithubIcon },
  { href: 'https://www.npmjs.com/package/surimi', text: 'NPM', icon: NpmIcon },
];

const pathname = Astro.url.pathname;
const isActive = (href: string) => pathname === href || pathname.startsWith(href + '/');
---

<div class="header">
  <a href="/" class="header__title">
    <h1>🍣 <span>surimi</span></h1>
  </a>

  <button class="header__toggle">
    <span class="header__toggle-icon" set:html={BarsIcon.html} />
  </button>

  <div class="header__backdrop"></div>

  <div class="header__right">
    <nav class="header__nav">
      {
        NAV_LINKS.map(link => (
          <a
            class:list={['header__nav-link', { 'header__nav-link--active': isActive(link.href) }]}
            href={link.href}
            aria-current={isActive(link.href) ? 'page' : undefined}
          >
            {link.text}
          </a>
        ))
      }
    </nav>
    <div class="header__social">
      {
        SOCIAL_LINKS.map(link => (
          <a class="header__social-link" href={link.href} aria-label={link.text} target="_blank" rel="noopener">
            <Fragment set:html={link.icon.html} />
          </a>
        ))
      }
    </div>
  </div>
</div>

<script lang="ts">
  const headerToggleButton = document.querySelector('.header__toggle');
  const header = document.querySelector('.header');
  const headerBackdrop = document.querySelector('.header__backdrop');

  headerToggleButton?.addEventListener('click', () => {
    header?.classList.toggle('header--open');
  });

  headerBackdrop?.addEventListener('click', () => {
    header?.classList.remove('header--open');
  });
</script>
