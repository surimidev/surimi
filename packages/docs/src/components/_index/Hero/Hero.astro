---
import { ArrowLeftIcon, LightbulbIcon } from '../../icons';

import './Hero.css';
---

<div class="hero">
  <h1 class="hero__title">
    Modern CSS just
    <br />
    got
    <div class="hero__title__gradient">even better!</div>
  </h1>
  <p class="hero__subtitle">
    Surimi is the next generation of CSS tooling. Think traditional CSS preprocessors, but with the power of Typescript
    and Rust built in.
  </p>
  <div class="hero__buttons">
    <a class="hero__button hero__button--primary" href="/docs/getting-started">
      Get Started
      <span class="hero__button__icon" set:html={ArrowLeftIcon.html} />
    </a>
    <a class="hero__button hero__button--secondary" href="/docs/reference">
      <span class="hero__button__icon" set:html={LightbulbIcon.html} />
      Why Surimi?
    </a>
  </div>
</div>
