---
import { BoltIcon, CodeIcon, LightbulbIcon, ShieldHalvedIcon } from '../../icons';

import './FeaturesSection.css';

const features = [
  {
    icon: ShieldHalvedIcon,
    title: 'Type-safe CSS',
    description:
      'No more wrong variable names, missing units etc. Surimi is pure typescript, so you see all errors in your editor (and the console).',
  },
  {
    icon: LightbulbIcon,
    title: 'Perfect DX',
    description:
      'Get autocomplete, type hints, inline docs, compatibility notes, spec information and more. right in your editor as you type.',
  },
  {
    icon: BoltIcon,
    title: 'No language barrier',
    description:
      "Built-in support for mixins, composition and more. And it's TypeScript! So use loops, functions, objects, nesting - all of it, fully typed.",
  },
  {
    icon: CodeIcon,
    title: 'Zero learning curve',
    description:
      "If you already know CSS and TypeScript, you know Surimi. And if not, Surimi show's you all your options. Just one hover away.",
  },
];
---

<section class="features-section">
  <div class="features-section__container">
    <h2 class="features-section__title">Not another preprocessor</h2>
    <p class="features-section__subtitle">
      CSS preprocessors like SCSS are great, but as CSS is getting more and more modern,
      <b>they solve less and less problems</b>. Today, <b>CSS's biggest problems</b> are
      <b>Developer experience, type-safety, composability, extensibility, complex selectors etc.</b>
      and Surimi solves all of them.
    </p>

    <div class="features-section__grid">
      {
        features.map(feature => (
          <div class="features-section-card">
            <div class="features-section-card__icon" set:html={feature.icon.html} />
            <h3 class="features-section-card__title">{feature.title}</h3>
            <p class="features-section-card__description">{feature.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
